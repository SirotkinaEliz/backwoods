<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#0f0f1a"
    android:paddingTop="80dp"
    android:paddingBottom="32dp"
    android:paddingStart="32dp"
    android:paddingEnd="32dp">

    <!-- App title -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GLUSH"
        android:textSize="52sp"
        android:textColor="#2CA5E0"
        android:textStyle="bold"
        android:letterSpacing="0.15"/>

    <TextView
        android:id="@+id/appSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WireGuard VPN"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp"/>

    <!-- Status indicator circle -->
    <TextView
        android:id="@+id/statusIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⬤"
        android:textSize="64sp"
        android:textColor="#888888"
        android:layout_marginTop="48dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VPN отключён"
        android:textSize="18sp"
        android:textColor="#CCCCCC"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/serverInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginTop="6dp"
        android:visibility="gone"/>

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Connect/Disconnect button -->
    <Button
        android:id="@+id/btnToggleVpn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Подключить VPN"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2CA5E0"
        android:layout_marginBottom="16dp"/>

    <!-- Version info -->
    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0 · Android"
        android:textSize="11sp"
        android:textColor="#444444"/>

</LinearLayout>
